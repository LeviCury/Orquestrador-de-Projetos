# ─── LDAP / Active Directory ───
LDAP_SERVER=ldap://your-ad-server:389
LDAP_BASE_DN=OU=YourOrg,DC=example,DC=local
LDAP_SVC_USER=svc_account_name
LDAP_SVC_PASSWORD=

# ─── JWT ───
JWT_SECRET=generate-a-strong-random-secret-here

# ─── Dominio de email permitido ───
ALLOWED_EMAIL_DOMAIN=example.com

# ─── GLPI API ───
GLPI_BASE_URL=https://your-glpi-instance.com/apirest.php
GLPI_APP_TOKEN=
GLPI_AUTH_BASIC=

# ─── CORS (comma-separated origins) ───
CORS_ORIGINS=http://localhost:5173
